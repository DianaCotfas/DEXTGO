# ─────────────────────────────────────────────────────────────────────────────
# DEXTGO — Phase 2 environment template
# Copy to `.env.local` and fill values as Diana provides them.
# Public keys (NEXT_PUBLIC_*) ship to the browser — never put secrets there.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site
# Optional explicit auth callback/signout origin (recommended in production).
# Example: https://dextgo.com
NEXT_PUBLIC_AUTH_REDIRECT_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Comma-separated list of admin emails granted CMS access.
ADMIN_EMAILS=

# ── Supabase (Auth + Postgres + Storage backup)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional CLI auth for automatic `npm run db:push` / `npm run dev` migration sync
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
# Optional if your CLI prompts for DB password during `supabase link`
SUPABASE_DB_PASSWORD=

# ── Stripe (Payments)
# test | live
STRIPE_MODE=test
# Use sk_test_... when STRIPE_MODE=test, sk_live_... when STRIPE_MODE=live
STRIPE_SECRET_KEY=
# Use the webhook signing secret from the matching Stripe mode (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Use pk_test_... when STRIPE_MODE=test, pk_live_... when STRIPE_MODE=live
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Mapbox (Interactive maps)
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── ElevenLabs (Audio guides)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Resend (Transactional email + newsletter)
RESEND_API_KEY=
# Must be a sender on a verified Resend domain (for quick tests: onboarding@resend.dev).
RESEND_FROM_EMAIL=hello@dextgo.com
# Comma-separated recipients for contact + custom itinerary notifications.
# Example: info@dextgo.com,yourname@gmail.com
CONTACT_NOTIFICATION_EMAILS=info@dextgo.com
RESEND_INBOX_EMAIL=info@dextgo.com
RESEND_AUDIENCE_ID=

# ── Cloudflare R2 (Image storage, S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dextgo-media
# Optional: public media base (e.g. https://media.example.com). Leave empty
# when using private bucket mode with the built-in /api/media proxy route.
NEXT_PUBLIC_R2_PUBLIC_BASE=
# Private media proxy signing (optional)
MEDIA_PROXY_SIGNING_SECRET=
MEDIA_PROXY_TTL_SECONDS=31536000

# ── Cloudflare Stream (Video hosting)
CLOUDFLARE_STREAM_API_TOKEN=
NEXT_PUBLIC_CLOUDFLARE_STREAM_BASE=https://customer-XXXX.cloudflarestream.com

# ── Iubenda (Legal pages + cookie banner)
NEXT_PUBLIC_IUBENDA_SITE_ID=
NEXT_PUBLIC_IUBENDA_COOKIE_POLICY_ID=
NEXT_PUBLIC_IUBENDA_PRIVACY_POLICY_ID=
NEXT_PUBLIC_IUBENDA_TERMS_POLICY_ID=
# Unified embedding widget UUID (recommended) — found in Iubenda dashboard
# under "Unified embedding code" for the Privacy Controls and Cookie Solution.
NEXT_PUBLIC_IUBENDA_WIDGET_ID=
